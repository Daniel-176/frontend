{
  "name": "mppnet",
  "version": "1.0.0",
  "license": "MIT",
  "devDependencies": {
    "@types/jquery": "^3.5.0",
    "esbuild": "^0.17.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "bun run build:main && bun run build:worklet",
    "build:main": "bun build src/main.ts --outfile=client/script.js --outdir=client/ --entry-naming=[dir]/script.[ext] --sourcemap=linked --format=iife --target=browser",
    "build:worklet": "bun build src/piano/piano-worklet-processor.ts --outfile=client/piano-worklet-processor.js --format=esm --target=browser",
    "build:min": "bun run build:main -- --minify && bun run build:worklet -- --minify",
    "typecheck": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "@types/bun": "^1.3.14",
    "i18nextify": "3.3.1"
  }
}
